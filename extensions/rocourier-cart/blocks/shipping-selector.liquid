{% comment %}
  RoCourier — Cart Shipping Selector
  Adds 4 delivery options to the cart page:
    1. FAN Courier – home delivery
    2. FANbox – locker pickup (opens map)
    3. Sameday – home delivery
    4. Sameday easybox – locker pickup (opens map)

  HOW TO ADD TO YOUR THEME:
  1. Shopify Admin → Online Store → Themes → Customize
  2. Navigate to the Cart page template
  3. Click "Add block" inside the cart section → choose "RoCourier Shipping"
  4. In block settings set the App URL to your Railway URL
{% endcomment %}

<div
  id="rocourier-widget"
  class="rocourier-widget"
  data-shop="{{ shop.permanent_domain }}"
  data-app-url="{{ block.settings.app_url }}"
  data-fan-enabled="{{ block.settings.fan_enabled }}"
  data-sameday-enabled="{{ block.settings.sameday_enabled }}"
>

  <p class="rc-section-title">
    {{ block.settings.title | default: 'Metoda de livrare:' }}
  </p>

  <div class="rc-methods" role="radiogroup" aria-label="Metoda de livrare">

    {%- if block.settings.fan_enabled -%}

      {%- comment -%} FAN Courier – home delivery {%- endcomment -%}
      <label class="rc-method-row" for="rc-fan-home">
        <input type="radio" id="rc-fan-home" name="rc_delivery" value="fan_home">
        <span class="rc-method-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 5v3h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
        </span>
        <span class="rc-method-text">
          <strong>FAN Courier</strong>
          <small>{{ block.settings.fan_home_sub | default: 'Livrare la domiciliu' }}</small>
        </span>
        <span class="rc-method-radio"></span>
      </label>

      {%- comment -%} FANbox – locker {%- endcomment -%}
      <label class="rc-method-row" for="rc-fan-box">
        <input type="radio" id="rc-fan-box" name="rc_delivery" value="fan_box">
        <span class="rc-method-icon rc-icon-box">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="18" rx="2"/><line x1="2" y1="9" x2="22" y2="9"/><line x1="12" y1="9" x2="12" y2="21"/></svg>
        </span>
        <span class="rc-method-text">
          <strong>FANbox</strong>
          <small>{{ block.settings.fan_box_sub | default: 'Ridicare din locker FAN' }}</small>
        </span>
        <span class="rc-method-radio"></span>
      </label>

    {%- endif -%}

    {%- if block.settings.sameday_enabled -%}

      {%- comment -%} Sameday – home delivery {%- endcomment -%}
      <label class="rc-method-row" for="rc-sameday-home">
        <input type="radio" id="rc-sameday-home" name="rc_delivery" value="sameday_home">
        <span class="rc-method-icon rc-icon-sameday">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 5v3h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
        </span>
        <span class="rc-method-text">
          <strong>Sameday</strong>
          <small>{{ block.settings.sameday_home_sub | default: 'Livrare la domiciliu' }}</small>
        </span>
        <span class="rc-method-radio"></span>
      </label>

      {%- comment -%} Sameday easybox – locker {%- endcomment -%}
      <label class="rc-method-row" for="rc-sameday-box">
        <input type="radio" id="rc-sameday-box" name="rc_delivery" value="sameday_box">
        <span class="rc-method-icon rc-icon-sameday rc-icon-box">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="18" rx="2"/><line x1="2" y1="9" x2="22" y2="9"/><line x1="12" y1="9" x2="12" y2="21"/></svg>
        </span>
        <span class="rc-method-text">
          <strong>Sameday easybox</strong>
          <small>{{ block.settings.sameday_box_sub | default: 'Ridicare din locker Sameday' }}</small>
        </span>
        <span class="rc-method-radio"></span>
      </label>

    {%- endif -%}

  </div>

  {%- comment -%} Selected pickup point (shown after choosing a locker) {%- endcomment -%}
  <div id="rc-point-selected" class="rc-point-selected" style="display:none;">
    <span id="rc-point-badge" class="rc-point-badge"></span>
    <div class="rc-point-info">
      <strong id="rc-point-name"></strong>
      <span id="rc-point-addr"></span>
    </div>
    <button type="button" id="rc-change-point" class="rc-change-btn">Schimbă</button>
  </div>

  {%- comment -%} Error / validation message {%- endcomment -%}
  <div id="rc-error" class="rc-error" style="display:none;"></div>

</div>

{%- comment -%} ── MAP MODAL ──────────────────────────────────────────────── {%- endcomment -%}
<div id="rc-modal" class="rc-modal" style="display:none;" role="dialog" aria-modal="true">
  <div class="rc-modal-backdrop" id="rc-modal-backdrop"></div>
  <div class="rc-modal-inner">

    <div class="rc-modal-header">
      <div class="rc-modal-search-wrap">
        <svg class="rc-search-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input
          type="text"
          id="rc-search"
          class="rc-search-input"
          placeholder="{{ block.settings.search_placeholder | default: 'Oraș, cod poștal, adresă...' }}"
          autocomplete="off"
        >
      </div>
      <div class="rc-modal-filters" id="rc-type-filters">
        {%- if block.settings.fan_enabled -%}
          <button type="button" class="rc-filter-btn rc-filter-active" data-courier="all">Toate</button>
          <button type="button" class="rc-filter-btn" data-courier="fan">FANbox</button>
        {%- endif -%}
        {%- if block.settings.sameday_enabled -%}
          <button type="button" class="rc-filter-btn" data-courier="sameday">easybox</button>
        {%- endif -%}
      </div>
      <button type="button" id="rc-modal-close" class="rc-modal-close" aria-label="Închide">✕</button>
    </div>

    <div class="rc-modal-body">

      {%- comment -%} Left: scrollable list {%- endcomment -%}
      <div class="rc-list-panel">
        <div id="rc-list-loading" class="rc-list-loading">
          <div class="rc-spinner"></div>
          <span>Se încarcă punctele de ridicare...</span>
        </div>
        <div id="rc-list-empty" style="display:none;" class="rc-list-empty">
          Niciun punct găsit în această zonă.
        </div>
        <ul id="rc-points-list" class="rc-points-list"></ul>
        <div id="rc-list-count" class="rc-list-count" style="display:none;"></div>
      </div>

      {%- comment -%} Right: Leaflet map {%- endcomment -%}
      <div class="rc-map-panel">
        <div id="rc-map"></div>
      </div>

    </div>

  </div>
</div>

{%- comment -%} Hidden cart attribute inputs (submitted with cart form) {%- endcomment -%}
<input type="hidden" id="rc-h-method"    name="attributes[_rc_method]"       value="">
<input type="hidden" id="rc-h-courier"   name="attributes[_rc_courier]"      value="">
<input type="hidden" id="rc-h-point-id"  name="attributes[_rc_point_id]"     value="">
<input type="hidden" id="rc-h-point-nm"  name="attributes[_rc_point_name]"   value="">
<input type="hidden" id="rc-h-point-ad"  name="attributes[_rc_point_address]" value="">

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="">
<link rel="stylesheet" href="{{ 'rocourier.css' | asset_url }}">
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV/XN2GqM=" crossorigin="" defer></script>
<script src="{{ 'rocourier.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "RoCourier Shipping",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "app_url",
      "label": "App URL",
      "default": "https://rocourier-production.up.railway.app",
      "info": "URL-ul aplicației RoCourier de pe Railway"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Titlu secțiune",
      "default": "Metoda de livrare:"
    },
    {
      "type": "header",
      "content": "FAN Courier"
    },
    { "type": "checkbox", "id": "fan_enabled",    "label": "Activează FAN Courier",          "default": true },
    { "type": "text",     "id": "fan_home_sub",   "label": "Sub-text livrare acasă FAN",      "default": "Livrare la domiciliu" },
    { "type": "text",     "id": "fan_box_sub",    "label": "Sub-text FANbox",                 "default": "Ridicare din locker FAN" },
    {
      "type": "header",
      "content": "Sameday"
    },
    { "type": "checkbox", "id": "sameday_enabled",   "label": "Activează Sameday",              "default": true },
    { "type": "text",     "id": "sameday_home_sub",  "label": "Sub-text livrare acasă Sameday", "default": "Livrare la domiciliu" },
    { "type": "text",     "id": "sameday_box_sub",   "label": "Sub-text easybox",               "default": "Ridicare din locker Sameday" },
    {
      "type": "header",
      "content": "Hartă"
    },
    { "type": "text", "id": "search_placeholder", "label": "Placeholder căutare", "default": "Oraș, cod poștal, adresă..." }
  ]
}
{% endschema %}
