{% comment %}
  RoCourier — Unified Shipping Selector
  2 rows: Home Delivery (courier chip picker) + Pickup Point (map)
{% endcomment %}

<div
  id="rocourier-widget"
  class="rocourier-widget"
  data-shop="{{ shop.permanent_domain }}"
  data-app-url="{{ block.settings.app_url }}"
  data-currency="{{ cart.currency.iso_code | default: 'RON' }}"
  data-lang="{{ request.locale.iso_code | slice: 0, 2 | downcase }}"
  data-fan-enabled="{{ block.settings.fan_enabled }}"
  data-fan-home-fee="{{ block.settings.fan_home_fee | default: 0 }}"
  data-fan-pickup-fee="{{ block.settings.fan_pickup_fee | default: 0 }}"
  data-fan-logo="{{ 'logo-fan.svg' | asset_url }}"
  data-sameday-enabled="{{ block.settings.sameday_enabled }}"
  data-sameday-home-fee="{{ block.settings.sameday_home_fee | default: 0 }}"
  data-sameday-pickup-fee="{{ block.settings.sameday_pickup_fee | default: 0 }}"
  data-sameday-logo="{{ 'logo-sameday.svg' | asset_url }}"
  data-cargus-enabled="{{ block.settings.cargus_enabled }}"
  data-cargus-home-fee="{{ block.settings.cargus_home_fee | default: 0 }}"
  data-cargus-pickup-fee="{{ block.settings.cargus_pickup_fee | default: 0 }}"
  data-cargus-logo="{{ 'logo-cargus.svg' | asset_url }}"
  data-gls-enabled="{{ block.settings.gls_enabled }}"
  data-gls-home-fee="{{ block.settings.gls_home_fee | default: 0 }}"
  data-gls-pickup-fee="{{ block.settings.gls_pickup_fee | default: 0 }}"
  data-gls-logo="{{ 'logo-gls.svg' | asset_url }}"
  data-packeta-enabled="{{ block.settings.packeta_enabled }}"
  data-packeta-home-fee="{{ block.settings.packeta_home_fee | default: 0 }}"
  data-packeta-pickup-fee="{{ block.settings.packeta_pickup_fee | default: 0 }}"
  data-packeta-logo="{{ 'logo-packeta.svg' | asset_url }}"
>

  <p class="rc-section-title" id="rc-section-title">
    {{ block.settings.title | default: 'Metoda de livrare:' }}
  </p>

  <div class="rc-methods" role="radiogroup" aria-label="Metoda de livrare">

    <!-- ── HOME DELIVERY row ───────────────────────────────────────────── -->
    <label class="rc-method-row" for="rc-home">
      <input type="radio" id="rc-home" name="rc_delivery" value="home">
      <span class="rc-method-icon rc-icon-home">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="1" y="3" width="15" height="13" rx="1"/>
          <path d="M16 8h4l3 5v3h-7V8z"/>
          <circle cx="5.5" cy="18.5" r="2.5"/>
          <circle cx="18.5" cy="18.5" r="2.5"/>
        </svg>
      </span>
      <span class="rc-method-text">
        <strong id="rc-home-label">Livrare la domiciliu</strong>
        <small id="rc-home-sub">Alege curierul preferat</small>
      </span>
      <span id="rc-home-fee" class="rc-method-fee"></span>
      <span class="rc-method-radio"></span>
    </label>

    <!-- Courier chip picker — shown when home is selected -->
    <div id="rc-courier-picker" class="rc-courier-picker" style="display:none;">
      {%- if block.settings.fan_enabled -%}
        <button type="button" class="rc-chip" data-courier="fan" data-color="#FF6600">
          <img src="{{ 'logo-fan.svg' | asset_url }}" alt="FAN Courier" class="rc-chip-logo" width="80" height="22">
        </button>
      {%- endif -%}
      {%- if block.settings.sameday_enabled -%}
        <button type="button" class="rc-chip" data-courier="sameday" data-color="#003DA5">
          <img src="{{ 'logo-sameday.svg' | asset_url }}" alt="Sameday" class="rc-chip-logo" width="80" height="22">
        </button>
      {%- endif -%}
      {%- if block.settings.cargus_enabled -%}
        <button type="button" class="rc-chip" data-courier="cargus" data-color="#E20020">
          <img src="{{ 'logo-cargus.svg' | asset_url }}" alt="Cargus" class="rc-chip-logo" width="80" height="22">
        </button>
      {%- endif -%}
      {%- if block.settings.gls_enabled -%}
        <button type="button" class="rc-chip" data-courier="gls" data-color="#003591">
          <img src="{{ 'logo-gls.svg' | asset_url }}" alt="GLS" class="rc-chip-logo" width="80" height="22">
        </button>
      {%- endif -%}
      {%- if block.settings.packeta_enabled -%}
        <button type="button" class="rc-chip" data-courier="packeta" data-color="#BA2025">
          <img src="{{ 'logo-packeta.svg' | asset_url }}" alt="Packeta" class="rc-chip-logo" width="80" height="22">
        </button>
      {%- endif -%}
    </div>

    <!-- ── PICKUP POINT row ────────────────────────────────────────────── -->
    <label class="rc-method-row rc-row-last" for="rc-pickup">
      <input type="radio" id="rc-pickup" name="rc_delivery" value="pickup">
      <span class="rc-method-icon rc-icon-box">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="2" y="3" width="20" height="18" rx="2"/>
          <line x1="2" y1="9" x2="22" y2="9"/>
          <line x1="12" y1="9" x2="12" y2="21"/>
        </svg>
      </span>
      <span class="rc-method-text">
        <strong id="rc-pickup-label">Ridicare din punct fix</strong>
        <small id="rc-pickup-sub">Locker, easybox, ParcelShop...</small>
      </span>
      <span id="rc-pickup-fee" class="rc-method-fee"></span>
      <span class="rc-method-radio"></span>
    </label>

  </div>

  <!-- Selected pickup point summary -->
  <div id="rc-point-selected" class="rc-point-selected" style="display:none;">
    <img id="rc-point-logo" class="rc-point-logo" src="{{ '' | asset_url }}" alt="" width="60" height="20">
    <div class="rc-point-info">
      <strong id="rc-point-name"></strong>
      <span id="rc-point-addr"></span>
    </div>
    <button type="button" id="rc-change-point" class="rc-change-btn"><!-- translated by JS --></button>
  </div>

  <div id="rc-error" class="rc-error" style="display:none;"></div>

</div>

{%- comment -%} MAP MODAL {%- endcomment -%}
<div id="rc-modal" class="rc-modal" style="display:none;" role="dialog" aria-modal="true">
  <div class="rc-modal-backdrop" id="rc-modal-backdrop"></div>
  <div class="rc-modal-inner">

    <div class="rc-modal-header">
      <div class="rc-modal-search-wrap">
        <svg class="rc-search-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input
          type="text"
          id="rc-search"
          class="rc-search-input"
          placeholder="{{ block.settings.search_placeholder | default: 'Oraș, cod poștal, adresă...' }}"
          autocomplete="off"
        >
      </div>
      <div class="rc-modal-filters" id="rc-type-filters">
        <button type="button" class="rc-filter-btn rc-filter-active" id="rc-filter-all" data-courier="all">Toate</button>
        {%- if block.settings.fan_enabled -%}
          <button type="button" class="rc-filter-btn" data-courier="fan">
            <img src="{{ 'logo-fan.svg' | asset_url }}" alt="FAN" class="rc-filter-logo" width="48" height="16">
          </button>
        {%- endif -%}
        {%- if block.settings.sameday_enabled -%}
          <button type="button" class="rc-filter-btn" data-courier="sameday">
            <img src="{{ 'logo-sameday.svg' | asset_url }}" alt="Sameday" class="rc-filter-logo" width="48" height="16">
          </button>
        {%- endif -%}
        {%- if block.settings.cargus_enabled -%}
          <button type="button" class="rc-filter-btn" data-courier="cargus">
            <img src="{{ 'logo-cargus.svg' | asset_url }}" alt="Cargus" class="rc-filter-logo" width="48" height="16">
          </button>
        {%- endif -%}
        {%- if block.settings.gls_enabled -%}
          <button type="button" class="rc-filter-btn" data-courier="gls">
            <img src="{{ 'logo-gls.svg' | asset_url }}" alt="GLS" class="rc-filter-logo" width="48" height="16">
          </button>
        {%- endif -%}
        {%- if block.settings.packeta_enabled -%}
          <button type="button" class="rc-filter-btn" data-courier="packeta">
            <img src="{{ 'logo-packeta.svg' | asset_url }}" alt="Packeta" class="rc-filter-logo" width="48" height="16">
          </button>
        {%- endif -%}
      </div>
      <button type="button" id="rc-modal-close" class="rc-modal-close" aria-label="Close">✕</button>
    </div>

    <div class="rc-modal-body">
      <div class="rc-list-panel">
        <div id="rc-list-loading" class="rc-list-loading">
          <div class="rc-spinner"></div>
          <span id="rc-loading-text">Se încarcă punctele de ridicare...</span>
        </div>
        <div id="rc-list-empty" style="display:none;" class="rc-list-empty"><!-- translated by JS --></div>
        <ul id="rc-points-list" class="rc-points-list"></ul>
        <div id="rc-list-count" class="rc-list-count" style="display:none;"></div>
      </div>
      <div class="rc-map-panel">
        <div id="rc-map"></div>
      </div>
    </div>

  </div>
</div>

<input type="hidden" id="rc-h-method"    name="attributes[_rc_method]"        value="">
<input type="hidden" id="rc-h-courier"   name="attributes[_rc_courier]"       value="">
<input type="hidden" id="rc-h-point-id"  name="attributes[_rc_point_id]"      value="">
<input type="hidden" id="rc-h-point-nm"  name="attributes[_rc_point_name]"    value="">
<input type="hidden" id="rc-h-point-ad"  name="attributes[_rc_point_address]" value="">

<link rel="stylesheet" href="{{ 'leaflet.css' | asset_url }}">
<link rel="stylesheet" href="{{ 'rocourier.css' | asset_url }}">
<script src="{{ 'leaflet.js' | asset_url }}" defer></script>
<script src="{{ 'rocourier.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "RoCourier Shipping",
  "target": "section",
  "settings": [
    { "type": "text",     "id": "app_url",            "label": "App URL",              "default": "https://rocourier-production.up.railway.app" },
    { "type": "text",     "id": "title",              "label": "Titlu secțiune",       "default": "Metoda de livrare:" },
    { "type": "text",     "id": "search_placeholder", "label": "Placeholder căutare",  "default": "Oraș, cod poștal, adresă..." },
    { "type": "header",   "content": "FAN Courier" },
    { "type": "checkbox", "id": "fan_enabled",        "label": "Activează FAN Courier","default": true },
    { "type": "number",   "id": "fan_home_fee",       "label": "Tarif livrare acasă (RON)", "default": 0 },
    { "type": "number",   "id": "fan_pickup_fee",     "label": "Tarif FANbox (RON)",   "default": 0 },
    { "type": "header",   "content": "Sameday" },
    { "type": "checkbox", "id": "sameday_enabled",    "label": "Activează Sameday",    "default": false },
    { "type": "number",   "id": "sameday_home_fee",   "label": "Tarif livrare acasă (RON)", "default": 0 },
    { "type": "number",   "id": "sameday_pickup_fee", "label": "Tarif easybox (RON)",  "default": 0 },
    { "type": "header",   "content": "Cargus" },
    { "type": "checkbox", "id": "cargus_enabled",     "label": "Activează Cargus",     "default": false },
    { "type": "number",   "id": "cargus_home_fee",    "label": "Tarif livrare acasă (RON)", "default": 0 },
    { "type": "number",   "id": "cargus_pickup_fee",  "label": "Tarif Ship & Go (RON)","default": 0 },
    { "type": "header",   "content": "GLS" },
    { "type": "checkbox", "id": "gls_enabled",        "label": "Activează GLS",        "default": false },
    { "type": "number",   "id": "gls_home_fee",       "label": "Tarif livrare acasă (RON)", "default": 0 },
    { "type": "number",   "id": "gls_pickup_fee",     "label": "Tarif ParcelShop (RON)","default": 0 },
    { "type": "header",   "content": "Packeta" },
    { "type": "checkbox", "id": "packeta_enabled",    "label": "Activează Packeta",    "default": false },
    { "type": "number",   "id": "packeta_home_fee",   "label": "Tarif livrare acasă (RON)", "default": 0 },
    { "type": "number",   "id": "packeta_pickup_fee", "label": "Tarif Packeta Point (RON)", "default": 0 }
  ]
}
{% endschema %}
