# ─── Shopify App Credentials ────────────────────────────────────────────────
# Get from: partners.shopify.com → Your App → App Setup → Client credentials
SHOPIFY_API_KEY=your_shopify_api_key_here
SHOPIFY_API_SECRET=your_shopify_api_secret_here
SCOPES=read_orders,write_orders,read_shipping,write_shipping,write_fulfillments,read_fulfillments

# ─── Database ────────────────────────────────────────────────────────────────
# Railway PostgreSQL: railway.app → New Project → PostgreSQL → Variables
DATABASE_URL=postgresql://user:password@host:5432/railway

# ─── App URL ─────────────────────────────────────────────────────────────────
# Your hosted app URL (Railway, Render, Fly.io, etc.)
# During dev: shopify app dev auto-creates a tunnel, ignore this
HOST=https://your-app.railway.app

# ─── Security ────────────────────────────────────────────────────────────────
# 32-char random string for encrypting stored API passwords
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AES_SECRET_KEY=generate_a_32_byte_hex_string_here

# ─── FAN Courier SANDBOX (for testing before going live) ────────────────────
# Source: github.com/FAN-Courier/API-Docs (public test account)
FAN_TEST_CLIENT_ID=7032158
FAN_TEST_USERNAME=clienttest
FAN_TEST_PASSWORD=testing
FAN_API_BASE=https://api.fancourier.ro
# For production, leave empty - credentials stored per-shop in DB

# ─── Sameday SANDBOX ─────────────────────────────────────────────────────────
# Source: contact software@sameday.ro to get sandbox access
# Sandbox URL: https://sameday-api.demo.zitec.com
SAMEDAY_API_BASE=https://api.sameday.ro
SAMEDAY_SANDBOX_BASE=https://sameday-api.demo.zitec.com

# ─── Node Environment ────────────────────────────────────────────────────────
NODE_ENV=development
